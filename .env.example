# Supabase (DB gestionale + auth). Valori dal dashboard: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ... (anon public key)

# Opzionale, solo lato server (mai esporre al browser). Non necessaria con RLS.
# SUPABASE_SERVICE_ROLE_KEY=eyJ... (service_role secret)

# --- AI reale (Claude / Anthropic) ---
# Chiave segreta SOLO lato server (mai NEXT_PUBLIC). Dal console.anthropic.com.
# ANTHROPIC_API_KEY=sk-ant-...
# Interruttore: "true" attiva l'AI reale via /api/ai; assente o "false" = modalita simulata (demo).
# NEXT_PUBLIC_AI_COLLEGATO=false

# --- DB sentenze reale (Lisia) ---
# URL base dell'API sentenze (dalla documentazione).
# SENTENZE_API_URL=https://aiapi.lisia.it
# Chiave segreta SOLO lato server (header "Authorization: ApiKey <token>"). Dal vecchio sviluppatore.
# SENTENZE_API_KEY=aa_key_...
# Interruttore: "true" attiva la ricerca reale; assente o "false" = modalita simulata (demo).
# NEXT_PUBLIC_SENTENZE_COLLEGATO=false
